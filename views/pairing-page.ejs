<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alexa AI | Pairing Portal</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: "Segoe UI", sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:
        radial-gradient(circle at top left,#1a1a1a,#050505 60%);
    color:#fff;
}

.box{
    width:380px;
    padding:35px;
    border-radius:20px;
    background:rgba(20,20,20,0.95);
    border:1px solid rgba(255,255,255,0.08);
    box-shadow:
        0 0 30px rgba(0,0,0,0.6),
        inset 0 0 20px rgba(255,255,255,0.02);
    backdrop-filter: blur(15px);
}

.logo{
    width:70px;
    height:70px;
    margin:auto;
    margin-bottom:15px;
    border-radius:50%;
    background:linear-gradient(135deg,#ffffff,#666666);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:28px;
    font-weight:bold;
    color:#000;
}

h2{
    text-align:center;
    margin-bottom:10px;
    font-size:28px;
    letter-spacing:1px;
}

.subtitle{
    text-align:center;
    color:#aaa;
    font-size:14px;
    margin-bottom:25px;
    line-height:1.5;
}

input{
    width:100%;
    padding:14px;
    background:#0f0f0f;
    border:1px solid #222;
    border-radius:12px;
    color:white;
    outline:none;
    transition:.3s;
    margin-bottom:15px;
}

input:focus{
    border-color:#888;
    box-shadow:0 0 15px rgba(255,255,255,0.15);
}

button{
    width:100%;
    padding:14px;
    border:none;
    border-radius:12px;
    background:linear-gradient(135deg,#ffffff,#9c9c9c);
    color:#000;
    font-weight:700;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    transform:translateY(-2px);
}

#codeDisplay{
    margin-top:20px;
    padding:15px;
    border-radius:12px;
    background:#0c0c0c;
    border:1px solid #222;
    text-align:center;
    font-size:18px;
    font-weight:bold;
    color:#fff;
    min-height:55px;
    display:flex;
    align-items:center;
    justify-content:center;
}

.footer{
    margin-top:15px;
    text-align:center;
    color:#666;
    font-size:12px;
}
</style>
</head>
<body>

<div class="box">

    <div class="logo">A</div>

    <h2>Alexa AI</h2>

    <p class="subtitle">
        Connect your WhatsApp account using a secure pairing code.
    </p>

    <input
        type="text"
        id="phone"
        placeholder="23480xxxxxxxx"
    >

    <button onclick="requestPairing()">
        Generate Pairing Code
    </button>

    <div id="codeDisplay">Waiting...</div>

    <div class="footer">
        Alexa AI • WhatsApp Connection Portal
    </div>

</div>
<script>
async function requestPairing() {
    const phoneInput = document.getElementById('phone');
    const display = document.getElementById('codeDisplay');
    
    // 1. Sanitize: Remove all non-numeric characters (spaces, +, dashes)
    const phone = phoneInput.value.replace(/\D/g, '');

    if (!phone) {
        display.innerText = "Please enter a valid number";
        return;
    }

    display.innerText = "Generating Code...";

    try {
        // 2. Fetch from your backend
        const res = await fetch(`/api/pair?phone=${phone}`);
        const data = await res.json();

        // 3. Handle response
        if (res.ok && data.pairingCode) {
            display.innerText = data.pairingCode;
        } else {
            // Display the specific error from the server, or a fallback
            display.innerText = data.error || "Unable to generate code";
            console.error("Server Error:", data.error);
        }

    } catch (err) {
        // 4. Handle connection crashes
        display.innerText = "Server Error";
        console.error("Fetch Error:", err);
    }
}
</script>
</body>
</html>
