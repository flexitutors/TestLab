<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chat with Alexa AI</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:"Segoe UI",sans-serif;
}

body{
    background:#050505;
    color:white;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

/* MAIN BOX */
.chat-container{
    width:100%;
    max-width:700px;
    height:85vh;
    background:rgba(20,20,20,.95);
    border:1px solid rgba(255,255,255,.08);
    border-radius:20px;
    display:flex;
    flex-direction:column;
    box-shadow:0 0 30px rgba(0,0,0,.8);
    backdrop-filter:blur(15px);
    overflow:hidden;
}

/* HEADER BAR */
.chat-header{
    padding:15px 20px;
    border-bottom:1px solid rgba(255,255,255,.08);
    font-size:14px;
    color:#bbb;
}

/* CHAT WINDOW */
#chat-window{
    flex:1;
    overflow-y:auto;
    padding:20px;
    display:flex;
    flex-direction:column;
    gap:12px;
}

/* MESSAGES */
.message{
    max-width:75%;
    padding:12px 14px;
    border-radius:14px;
    font-size:14px;
    line-height:1.5;
    word-wrap:break-word;
}

/* USER */
.user{
    background:#2a2a2a;
    border:1px solid #333;
    align-self:flex-end;
}

/* BOT */
.bot{
    background:#111;
    border:1px solid #222;
    align-self:flex-start;
    color:#ddd;
}

/* INPUT AREA */
.input-area{
    display:flex;
    gap:10px;
    padding:15px;
    border-top:1px solid rgba(255,255,255,.08);
    background:rgba(15,15,15,.9);
}

input{
    flex:1;
    padding:14px;
    border-radius:12px;
    border:1px solid #222;
    background:#0f0f0f;
    color:white;
    outline:none;
}

input:focus{
    border-color:#555;
}

button{
    padding:14px 18px;
    border:none;
    border-radius:12px;
    background:linear-gradient(135deg,#ffffff,#9c9c9c);
    color:black;
    font-weight:700;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    transform:translateY(-2px);
}

/* SCROLLBAR */
#chat-window::-webkit-scrollbar{
    width:6px;
}

#chat-window::-webkit-scrollbar-thumb{
    background:#333;
    border-radius:10px;
}
</style>
</head>

<body>

<div class="chat-container">

    <div class="chat-header">
        🤖 Alexa AI • Neural Conversation Interface
    </div>

    <div id="chat-window"></div>

    <div class="input-area">
        <input type="text" id="msgInput" placeholder="Ask Alexa AI anything...">
        <button onclick="sendMessage()">Send</button>
    </div>

</div>
<script>
async function sendMessage() {
    const input = document.getElementById('msgInput');
    const chat = document.getElementById('chat-window');

    if (!input.value.trim()) return;

    const userText = input.value;
    input.value = '';

    // USER MESSAGE
    // Use insertAdjacentHTML instead of innerHTML +=
    chat.insertAdjacentHTML('beforeend', `<div class="message user">${userText}</div>`);
    chat.scrollTop = chat.scrollHeight;

    try {
        const res = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: userText })
        });

        const data = await res.json();

        // BOT MESSAGE
        // Ensure data.response contains the text you expect from your API
        const botResponse = data.response || "No response received.";
        chat.insertAdjacentHTML('beforeend', `<div class="message bot">${botResponse}</div>`);

    } catch (err) {
        console.error(err);
        chat.insertAdjacentHTML('beforeend', `<div class="message bot">System error: Unable to reach Alexa AI</div>`);
    }

    chat.scrollTop = chat.scrollHeight;
}
</script>
</body>
</html>
