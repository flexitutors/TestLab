<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alexa AI Dashboard</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:"Segoe UI",sans-serif;
}

body{
    background:#050505;
    color:white;
    min-height:100vh;
}

/* HERO HEADER */

.hero-header{
    position:relative;
    width:100%;
    height:320px;
    background:url('https://i.postimg.cc/vBTR0ZzG/images-(10).jpg') center center/cover no-repeat;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    overflow:hidden;
}

.hero-header::before{
    content:"";
    position:absolute;
    inset:0;
    background:
    linear-gradient(
        rgba(0,0,0,.75),
        rgba(0,0,0,.75)
    );
}

.hero-content{
    position:relative;
    z-index:2;
    padding:20px;
}

.hero-badge{
    display:inline-block;
    padding:8px 18px;
    border-radius:30px;
    border:1px solid rgba(255,255,255,.2);
    background:rgba(0,0,0,.35);
    backdrop-filter:blur(10px);
    margin-bottom:15px;
    font-size:12px;
    letter-spacing:2px;
}

.hero-content h1{
    font-size:3rem;
    margin-bottom:10px;
}

.hero-content p{
    color:#cfcfcf;
    max-width:700px;
    margin:auto;
    line-height:1.6;
}

/* DASHBOARD */

.dashboard{
    padding:30px;
    max-width:1300px;
    margin:auto;
}

.card-container{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
}

.card{
    text-decoration:none;
    color:white;
    background:rgba(20,20,20,.95);
    border:1px solid rgba(255,255,255,.08);
    border-radius:18px;
    padding:25px;
    transition:.3s;
    backdrop-filter:blur(15px);
    box-shadow:0 0 20px rgba(0,0,0,.4);
}

.card:hover{
    transform:translateY(-6px);
    border-color:rgba(255,255,255,.18);
    box-shadow:0 0 25px rgba(255,255,255,.08);
}

.card-badge{
    display:inline-block;
    margin-bottom:15px;
    padding:6px 12px;
    border-radius:20px;
    background:#111;
    border:1px solid #333;
    color:#ddd;
    font-size:12px;
}

.card h3{
    margin-bottom:12px;
    font-size:1.2rem;
}

.card p{
    color:#aaa;
    line-height:1.6;
}

#term-btn{
    margin-top:15px;
    padding:10px;
    width:100%;
    border:none;
    border-radius:10px;
    background:#d9534f;
    color:white;
    cursor:pointer;
}

#term-btn:hover{
    opacity:.9;
}

footer{
    text-align:center;
    color:#666;
    padding:30px 20px;
    border-top:1px solid #111;
    margin-top:40px;
}

@media(max-width:768px){

    .hero-header{
        height:280px;
    }

    .hero-content h1{
        font-size:2rem;
    }

    .dashboard{
        padding:20px;
    }

}

</style>
</head>

<body>


<header class="hero-header">

<div class="hero-content">

<div class="hero-badge">
ALEXA AI CONTROL CENTER
</div>

<h1>
Welcome to Alexa AI Platform
</h1>

<p>
Manage your WhatsApp AI assistant,
broadcasts, analytics,
system logs and intelligent
conversations from one centralized
dashboard.
</p>

</div>

</header>


<section class="dashboard">

<div class="card-container">


<!-- SESSION STATUS CARD -->

<div class="card" id="session-card">

<div class="card-badge"
id="status-badge">

CHECKING...

</div>

<h3 id="status-title">
Session Status
</h3>

<p>

Paired Number:

<strong id="num-display">

Loading...

</strong>

</p>

<button
id="term-btn"
onclick="terminateSession()"
style="display:none;"
>

Terminate Session

</button>

</div>



<!-- PAIR -->

<a href="/pair"
class="card">

<div class="card-badge">

PAIRING

</div>

<h3>

Pair with Alexa AI

</h3>

<p>

Connect your WhatsApp
instance securely
using a pairing code.

</p>

</a>



<!-- BROADCAST -->

<a href="/broadcast"
class="card">

<div class="card-badge">

BROADCAST

</div>

<h3>

Broadcast with Alexa

</h3>

<p>

Send announcements and perform
intelligent mass communication.

</p>

</a>



<!-- LOGS -->

<a href="/logs"
class="card">

<div class="card-badge">

SYSTEM LOGS

</div>

<h3>

View Alexa Logs

</h3>

<p>

Monitor activities,
commands, events
and performance.

</p>

</a>



<!-- CHAT -->

<a href="/chat"
class="card">

<div class="card-badge">

AI CHAT

</div>

<h3>

Chat with Alexa AI

</h3>

<p>

Interact directly
with Alexa's AI
brain in real time.

</p>

</a>



<!-- SUPPORT -->

<a href="tel:09034159839"
class="card">

<div class="card-badge">

SUPPORT

</div>

<h3>

Contact Us

</h3>

<p>

Support Line:
<%= contact %>

</p>

</a>

</div>

</section>


<footer>

© <%= new Date().getFullYear() %>
Alexa AI • Secure Intelligence Platform

</footer>


<script>

async function fetchSessionStatus(){

const numDisplay=
document.getElementById(
"num-display"
);

const badge=
document.getElementById(
"status-badge"
);

const title=
document.getElementById(
"status-title"
);

const termBtn=
document.getElementById(
"term-btn"
);

try{

badge.innerText=
"CHECKING...";

badge.style.background=
"#f0ad4e";


const response=
await fetch(
"/api/session"
);

if(!response.ok){

throw new Error(
"Fetch failed"
);

}

const data=
await response.json();


if(data.pairedNumber){

numDisplay.innerText=
data.pairedNumber;

title.innerText=
"Session Active";

badge.innerText=
"ONLINE";

badge.style.background=
"#28a745";

termBtn.style.display=
"block";

}

else{

numDisplay.innerText=
"Not Paired";

title.innerText=
"No Active Session";

badge.innerText=
"OFFLINE";

badge.style.background=
"#333";

termBtn.style.display=
"none";

}

}

catch(error){

console.log(error);

title.innerText=
"Connection Error";

numDisplay.innerText=
"Unavailable";

badge.innerText=
"ERROR";

badge.style.background=
"#dc3545";

termBtn.style.display=
"none";

}

}



async function terminateSession(){

if(
!confirm(
"Are you sure? This will unlink WhatsApp."
)
)
return;


const btn=
document.getElementById(
"term-btn"
);


try{

btn.disabled=true;

btn.innerText=
"Terminating...";


const response=
await fetch(
"/api/terminate",
{
method:"POST"
}
);

if(!response.ok){

throw new Error();

}

alert(
"Session terminated successfully"
);

fetchSessionStatus();

}

catch(err){

alert(
"Error terminating session"
);

}

finally{

btn.disabled=false;

btn.innerText=
"Terminate Session";

}

}



document.addEventListener(
"DOMContentLoaded",
()=>{

fetchSessionStatus();

setInterval(
fetchSessionStatus,
15000
);

}
);

</script>

</body>
</html>
